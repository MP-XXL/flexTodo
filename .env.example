# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=flextodo

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker (development):
DATABASE_URL=postgresql://flextodo_user:flextodo_secret@db:5432/flextodo_db

# Supabase (production) — use the "Transaction pooler" string from:
# Supabase Dashboard → Project → Settings → Database → Connection string
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Docker Compose only (not read by the app) ─────────────────────────────────
POSTGRES_USER=flextodo_user
POSTGRES_PASSWORD=flextodo_secret
POSTGRES_DB=flextodo_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Development: leave as "*"
# Production: set to your Vercel frontend URL (comma-separated for multiple)
# Example: https://flextodo.vercel.app
ALLOWED_ORIGINS=*